{
  "name": "@agentic-deployment/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @agentic-deployment/code-engine run build",
    "dev": "tsx src/index.ts",
    "prestart": "pnpm run build && pnpm --filter @agentic-deployment/code-engine run build",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agentic-deployment/code-engine": "workspace:*",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
